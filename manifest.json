{
    "name": "SchoL Extension",
    "description": "Random schol changes that make it better maybe?",
    "version": "3.0.0",
    "manifest_version": 3,
    "host_permissions": [
        "https://learning.stmichaels.vic.edu.au/*",
        "https://learning-dev.stmichaels.vic.edu.au/*"
    ],
    "permissions": ["storage", "tabs", "scripting", "activeTab", "webNavigation"],
    "web_accessible_resources": [
        {
            "resources": [
                "darkmodeImages/*",
                "compiled.js",
                "chrome_ext/storage.js",
                "chrome_ext/override.js",
                "chrome_ext/*"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "https://learning.stmichaels.vic.edu.au/*",
                "https://learning-dev.stmichaels.vic.edu.au/*"
            ],
            "js": [
                "chrome_ext/content.js"
            ],
            "run_at": "document_start",
            "all_frames": false
        }
    ],
    "background": {
        "service_worker": "chrome_ext/background.js"
    },
    "action" : {
        "default_popup": "chrome_ext/popup.html",
        "default_icon": {
            "16": "chrome_ext/Disabled.png",
            "48": "chrome_ext/Disabled.png",
            "128": "chrome_ext/Disabled.png"
        }
    },
    "icons": {
        "16": "chrome_ext/Disabled.png",
        "48": "chrome_ext/Disabled.png",
        "128": "chrome_ext/Disabled.png"
    }
}
